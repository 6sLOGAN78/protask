PROTASK_PRIMARY.ENV="local"

PROTASK_SERVER.PORT="8080"
PROTASK_SERVER.READ_TIMEOUT="30"
PROTASK_SERVER.WRITE_TIMEOUT="30"
PROTASK_SERVER.IDLE_TIMEOUT="60"
PROTASK_SERVER.CORS_ALLOWED_ORIGINS="http://localhost:3000"

PROTASK_DATABASE.HOST="localhost"
PROTASK_DATABASE.PORT="5432"
PROTASK_DATABASE.USER="postgres"
PROTASK_DATABASE.PASSWORD=""
PROTASK_DATABASE.NAME="protask"
PROTASK_DATABASE.SSL_MODE="disable"
PROTASK_DATABASE.MAX_OPEN_CONNS="25"
PROTASK_DATABASE.MAX_IDLE_CONNS="25"
PROTASK_DATABASE.CONN_MAX_LIFETIME="300"
PROTASK_DATABASE.CONN_MAX_IDLE_TIME="300"

PROTASK_AUTH.SECRET_KEY="secret"

PROTASK_INTEGRATION.RESEND_API_KEY="resend_key"

PROTASK_REDIS.ADDRESS="redis://localhost:6379"

# ============================================================================
# OBSERVABILITY CONFIGURATION
# ============================================================================

# Service Identity
PROTASK_OBSERVABILITY.SERVICE_NAME="protask"
PROTASK_OBSERVABILITY.ENVIRONMENT="development"

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Basic Logging Settings
PROTASK_OBSERVABILITY.LOGGING.LEVEL="debug"
PROTASK_OBSERVABILITY.LOGGING.FORMAT="console"
PROTASK_OBSERVABILITY.LOGGING.SLOW_QUERY_THRESHOLD="100ms"

# ============================================================================
# NEW RELIC CONFIGURATION
# ============================================================================

# New Relic APM
PROTASK_OBSERVABILITY.NEW_RELIC.LICENSE_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
PROTASK_OBSERVABILITY.NEW_RELIC.APP_LOG_FORWARDING_ENABLED="true"
PROTASK_OBSERVABILITY.NEW_RELIC.DISTRIBUTED_TRACING_ENABLED="true"
PROTASK_OBSERVABILITY.NEW_RELIC.DEBUG_LOGGING="false"

# ============================================================================
# HEALTH CHECKS CONFIGURATION
# ============================================================================

# Health Check Settings
PROTASK_OBSERVABILITY.HEALTH_CHECKS.ENABLED="true"
PROTASK_OBSERVABILITY.HEALTH_CHECKS.INTERVAL="30s"
PROTASK_OBSERVABILITY.HEALTH_CHECKS.TIMEOUT="5s"
PROTASK_OBSERVABILITY.HEALTH_CHECKS.CHECKS="database,redis"